          <span class="fit-highlight-line absolute left-0 -bottom-0.5 h-[2px] w-0 bg-[#4169E1] transition-all duration-700 ease-out rounded-full"></span>
        </span>
      </p>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════
     MOST IDEAS NEVER BECOME REAL — dark CTA
     Animation: text fades up in sequence
     ═══════════════════════════════════════════════════════════ -->
<section class="bg-[#0a0a0a] py-28 border-t border-white/10" id="build-cta-section">
  <div class="max-w-4xl mx-auto px-6 text-center">
    <div class="space-y-6">

      <div class="build-line opacity-0 translate-y-4 transition-all duration-600 ease-out text-3xl md:text-5xl leading-tight font-medium tracking-tight text-white" style="transition-delay:0ms;">
        Most ideas never become real.
      </div>
      <div class="build-line opacity-0 translate-y-4 transition-all duration-600 ease-out text-3xl md:text-5xl leading-tight font-medium tracking-tight text-white" style="transition-delay:150ms;">
        Not because they're bad —
      </div>
      <div class="build-line opacity-0 translate-y-4 transition-all duration-600 ease-out text-3xl md:text-5xl leading-tight font-medium tracking-tight text-white" style="transition-delay:300ms;">
        but because <span class="text-[#ff0088]">no one builds them.</span>
      </div>

      <div class="build-line opacity-0 translate-y-4 transition-all duration-600 ease-out text-2xl md:text-3xl text-gray-300 font-light tracking-tight mt-4" style="transition-delay:450ms;">
