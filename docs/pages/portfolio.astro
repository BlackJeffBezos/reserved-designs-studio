        href="https://canva.link/okot4yputwenf4k"
        imageSrc="/images/safari-canvas-logo-designed-by-reserved-designs.avif"
        imageAlt="South African inspired apparel maker & Market house, Safari Canvas Reserved Designs Studio  division."
        category="RSA Apparel Maker & Market Place"
        categoryColor="pink-600"
        borderColor="pink-500/30"
        title="Safari Canvas"
        description="Your heartbeat syncs with the bassline of a Jozi taxi rank. Your skin remembers the salt of Cape Town waves. Your soul hums with the fire of a thousand township braais. Now imagine wrapping that exact electricity around your body—every single day. While the world drowns in faded 'California Love' tees and sun-bleached Miami dreams, we’re rising with ink that bleeds red, gold, and green. Safari Canvas isn’t selling clothes. We’re bottling Mzansi magic and daring you to wear it unapologetically."
        partnerLabel="T-Shirt design, RSA Graphic T-Shirts Market Place"
        partnerName="Reserved Designs Studio."
        animationDelay="0.1s"
        data-tags="RSA Apparel Maker & Market Place, T-Shirt design, RSA Graphic T-Shirts Market Place ,South African Inspired Apparel, T-Shirt design, graphic design, logo, logo design."
      />

      <PortfolioCard
        href="case-studies/linkpod-casestudy.html"
