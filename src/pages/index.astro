<script>
  const btn = document.getElementById('basin-btn')
  const emailInput = document.getElementById('basin-email')
  const msg = document.getElementById('basin-msg')

  // ─── NUCLEAR REDIRECT LOCKDOWN ──────────────────────────────────────────────
  // Intercepts ALL navigation attempts during the Basin fetch window.
  // Fires before any redirect from Basin can take hold.

  let lockdown = false

  // 1. beforeunload — blocks tab close / hard nav
  const onBeforeUnload = (e) => {
    if (!lockdown) return
    e.preventDefault()
    e.returnValue = ''
  }

  // 2. Proxy window.location — intercepts .href = '...' and .replace()
  const _realLocation = window.location
  const locationProxy = new Proxy(_realLocation, {
    set(target, prop, value) {
      if (lockdown && prop === 'href') {
        console.warn('[BASIN LOCKDOWN] Blocked location.href redirect →', value)
        return true // swallow it
      }
      Reflect.set(target, prop, value)
      return true
    }
  })
  try {
    Object.defineProperty(window, 'location', {
      get: () => lockdown ? locationProxy : _realLocation,
      configurable: true
    })
  } catch (_) { /* Firefox restricts this — fallback below handles it */ }

  // 3. history API interception — pushState / replaceState
  const _pushState = history.pushState.bind(history)
  const _replaceState = history.replaceState.bind(history)
  history.pushState = (...args) => {
    if (lockdown) { console.warn('[BASIN LOCKDOWN] Blocked pushState →', args[2]); return }
    _pushState(...args)
  }
  history.replaceState = (...args) => {
    if (lockdown) { console.warn('[BASIN LOCKDOWN] Blocked replaceState →', args[2]); return }
    _replaceState(...args)
  }

  // 4. XMLHttpRequest + fetch monkey-patch — prevents Basin's own redirect-follow
  const _origFetch = window.fetch
  window.fetch = (input, init = {}) => {
    // Force no-follow on all fetches while locked (ours included — we handle it)
    return _origFetch(input, { redirect: 'manual', ...init })
  }

  // 5. popstate / hashchange killswitch
  const onNavEvent = (e) => { if (lockdown) e.stopImmediatePropagation() }
  window.addEventListener('popstate', onNavEvent, true)
  window.addEventListener('hashchange', onNavEvent, true)

  // ─── BASIN SUBMIT LOGIC ─────────────────────────────────────────────────────

  btn.addEventListener('click', async () => {
    const email = emailInput.value.trim()
    if (!email) return

    btn.disabled = true
    btn.textContent = 'Sending...'
    msg.textContent = ''

    // Arm the lockdown the instant we fire the request
    lockdown = true
    window.addEventListener('beforeunload', onBeforeUnload)

    try {
      const res = await fetch('https://usebasin.com/f/b12a06bd44cf', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        // _redirect: '' tells Basin: no server-side redirect
        body: JSON.stringify({ email, _redirect: '' })
      })

      // Disarm — we're safe now
      lockdown = false
      window.removeEventListener('beforeunload', onBeforeUnload)

      // Basin returns 200 or 302 (manual mode catches 302 as opaqueredirect)
      if (res.ok || res.type === 'opaqueredirect') {
        btn.textContent = "You're in"
        btn.style.backgroundColor = '#ff0088'
        btn.style.color = 'white'
        emailInput.style.display = 'none'
        msg.style.color = '#22c55e'
        msg.textContent = "Welcome. You'll hear from us soon."
      } else {
        throw new Error(`Basin responded: ${res.status}`)
      }
    } catch (err) {
      lockdown = false
      window.removeEventListener('beforeunload', onBeforeUnload)
      console.error('[BASIN]', err)
      btn.disabled = false
      btn.textContent = 'Accept Invitation'
      msg.style.color = '#ef4444'
      msg.textContent = 'Something went wrong. Try again.'
    }
  })
</script>
      
