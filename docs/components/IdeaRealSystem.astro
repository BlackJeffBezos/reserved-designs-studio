---
const ideaSteps = [
  {
    letter: "I",
    stage: "IDENTIFY",
    title: "REFINE<br>YOUR IDEA",
    description: "We turn your vision into a crystal-clear brief with sketches and requirements.",
  },
  {
    letter: "D",
    stage: "DESIGN",
    title: "PRECISE<br>CAD MODELS<br>& WIREFRAMES",
    description: "Professional, manufacturable 3D files & optimized logic wireframes for software, Apps & Websites.",
  },
  {
    letter: "E",
    stage: "ENGINEER",
    title: "MAKE IT<br>FUNCTIONAL",
    description: "Structural analysis, material selection, programming framework selection, cost optimization.",
  },
  {
    letter: "A",
    stage: "ASSEMBLE",
    title: "BUILD, TEST,<br>REFINE",
    description: "We 3D print, assemble, and iterate until your prototype works perfectly.",

  }
];

const realSteps = [
  {
    letter: "R",
    stage: "REFINE",
    title: "IMPROVE<br>DESIGN",
    description: "Enhance aesthetics, functionality and manufacturability.",
  },
  {
    letter: "E",
    stage: "EVALUATE",
    title: "TEST<br>USABILITY",
    description: "User testing, performance validation and feedback analysis.",
  },
  {
    letter: "A",
    stage: "ADJUST",
    title: "FIX<br>ISSUES",
    description: "Address problems, optimize and make final corrections.",
  },
  {
    letter: "L",
    stage: "LAUNCH",
    title: "READY FOR<br>PRODUCTION",
    description: "Final validated prototype ready for manufacturing/publication",
  }
];
---

<div class="bg-[#0a0a0a] py-20">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Header with Neon Gradient -->
    <div class="flex flex-col items-center text-center mb-16">
      <div class="flex items-center gap-4 mb-2">
        <h1 class="text-6xl md:text-7xl font-black tracking-tighter text-white">THE I.D.E.A</h1>
        <div class="neon-arrow">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-14 h-14" fill="none" viewBox="0 0 24 24" stroke="url(#neonGradient)" stroke-width="3">
            <defs>
              <linearGradient id="neonGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#00f5ff" />
                <stop offset="50%" stop-color="#ff00ff" />
                <stop offset="100%" stop-color="#ff0088" />
              </linearGradient>
            </defs>
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7-7 7" />
          </svg>
        </div>
      </div>
      <h2 class="text-6xl md:text-7xl font-black tracking-tighter text-white -mt-3">R.E.A.L SYSTEM</h2>
      
      <p class="mt-10 text-xl text-gray-300 max-w-md">
        You go from idea to real product in clear, predictable steps. No guesswork.
      </p>
    </div>

    <!-- I.D.E.A Row -->
    <div class="mb-20">
      <h3 class="text-transparent bg-clip-text bg-gradient-to-r from-[#00f5ff] via-[#ff00ff] to-[#ff0088] text-sm font-semibold tracking-[3px] uppercase mb-6 text-center">
        I.D.E.A — From Concept to Prototype
      </h3>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          ideaSteps.map((step) => (
            <div 
              class="idea-box group relative bg-[#111827] border border-[#00f5ff]/30 rounded-3xl overflow-hidden min-h-[420px] flex flex-col transition-all duration-500 hover:-translate-y-4 hover:scale-[1.03] hover:shadow-2xl hover:border-[#ff00ff]/40 cursor-pointer"
            >
              <!-- Background Letter -->
              <div class="letter absolute absolute top--60 right--60 text-[140px] font-white text-white/20 pointer-events-none transition-all duration-500 group-hover:text-white/20 group-hover:scale-110">
                {step.letter}
              </div>

              <div class="p-8 flex-1 flex flex-col">
                <div class="mb-auto">
                  <span class="uppercase text-[#00f5ff] text-sm font-semibold tracking-[2px]">{step.stage}</span>
                  <h3 class="text-3xl font-bold leading-none mt-4 text-white" set:html={step.title} />
                </div>
                <p class="text-gray-400 mt-auto text-[15px] leading-relaxed">
                  {step.description}
                </p>
              </div>

              <!-- Neon Gradient Bottom Bar -->
              <div class="h-3 bg-gradient-to-r from-[#00f5ff] via-[#ff00ff] to-[#ff0088]"></div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- R.E.A.L Row -->
    <div>
      <h3 class="text-transparent bg-clip-text bg-gradient-to-r from-[#00f5ff] via-[#ff00ff] to-[#ff0088] text-sm font-semibold tracking-[3px] uppercase mb-6 text-center">
        R.E.A.L — Refine to Launch
      </h3>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          realSteps.map((step) => (
            <div 
              class="idea-box group relative bg-[#111827] border border-[#00f5ff]/30 rounded-3xl overflow-hidden min-h-[420px] flex flex-col transition-all duration-500 hover:-translate-y-4 hover:scale-[1.03] hover:shadow-2xl hover:border-[#ff00ff]/40 cursor-pointer"
            >
              <!-- Background Letter -->
              <div class="letter absolute top--60 right--60 text-[140px] font-white text-white/20 pointer-events-none transition-all duration-500 group-hover:text-white/20 group-hover:scale-110">
                {step.letter}
              </div>


              <div class="p-8 flex-1 flex flex-col">
                <div class="mb-auto">
                  <span class="uppercase text-[#00f5ff] text-sm font-semibold tracking-[2px]">{step.stage}</span>
                  <h3 class="text-3xl font-bold leading-none mt-4 text-white" set:html={step.title} />
                </div>
                <p class="text-gray-400 mt-auto text-[15px] leading-relaxed">
                  {step.description}
                </p>
              </div>

              <!-- Neon Gradient Bottom Bar -->
              <div class="h-3 bg-gradient-to-r from-[#00f5ff] via-[#ff00ff] to-[#ff0088]"></div>
            </div>
          ))
        }
      </div>
    </div>

  </div>
</div>

<script>
  document.querySelectorAll('.idea-box').forEach((box) => {
    box.addEventListener('click', () => {
      box.style.transform = 'translateY(-22px) scale(1.07)';
      setTimeout(() => {
        box.style.transform = 'translateY(-12px) scale(1.03)';
      }, 650);
    });
  });
</script>

<style>
  .idea-box {
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .letter {
    transition: all 0.5s ease;
  }

  .neon-arrow {
    filter: drop-shadow(0 0 12px #00f5ff);
  }
</style>