---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Contact Us - Let's Turn Your Idea into Reality"
  description="Get in touch with Reserved Designs Studio. We're ready to help turn your ideas into loved products.">
<style>

  .reason-btn {
  transition: all 0.2s ease;
}

.reason-btn:hover {
  background-color: #eff6ff; /* light blue hover */
}

.reason-btn.bg-blue-600 {
  background-color: #2563eb;
  color: white;
  border-color: #1e40af;
}
</style>


<section class="py-16 md:py-24 px-4 sm:px-6 lg:px-8 bg-white">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
      
      <!-- Left: Form & Intro -->
      <div class="space-y-8 md:space-y-12">
        <!-- Bold Stacked Intro -->
        <div class="space-y-4">
          <h2 class="
            text-4xl sm:text-5xl md:text-6xl lg:text-7xl
            font-black tracking-tight leading-none
            text-blue-600
          ">
            GET IN <br>
            <span class="text-pink-600">TOUCH</span>
          </h2>

          <p class="text-lg md:text-xl lg:text-2xl text-gray-700 font-medium">
            We'd love to hear from you. Fill out the form below to book an appointment or send us a message.
          </p>
        </div>

<!-- Contact Form – Multiple reasons selectable -->
<form id="contact-form" class="space-y-6" action="https://usebasin.com/f/d1012b1e0982" method="POST" enctype="multipart/form-data">
  <!-- Your Name -->
  <div>
    <label class="block text-sm md:text-base font-bold text-gray-900 mb-2">
      YOUR NAME
    </label>
    <input
      type="text"
      name="name"
      placeholder="ENTER YOUR FULL NAME"
      required
      class="
        w-full px-5 py-4 rounded-xl border-2 border-gray-300
        focus:border-pink-600 focus:ring-2 focus:ring-pink-200
        bg-white text-gray-900 placeholder-gray-400
        transition-all duration-300
      "
    />
  </div>

  <!-- Email -->
  <div>
    <label class="block text-sm md:text-base font-bold text-gray-900 mb-2">
      EMAIL
    </label>
    <input
      type="email"
      name="email"
      placeholder="ENTER YOUR EMAIL"
      required
      class="
        w-full px-5 py-4 rounded-xl border-2 border-gray-300
        focus:border-pink-600 focus:ring-2 focus:ring-pink-200
        bg-white text-gray-900 placeholder-gray-400
        transition-all duration-300
      "
    />
  </div>

  <!-- Reason for Contact – Multiple selectable -->
  <div>
    <label class="block text-sm md:text-base font-bold text-gray-900 mb-2">
      REASON FOR CONTACT <span class="text-gray-500 text-sm font-normal">(select all that apply)</span>
    </label>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 reason-buttons">
      <button 
        type="button" 
        data-value="FEEDBACK" 
        class="reason-btn px-4 py-3 rounded-xl border-2 border-blue-600 bg-white text-blue-600 font-medium hover:bg-blue-50 transition-colors flex items-center justify-center gap-2"
      >
        <span>FEEDBACK</span>
        <svg class="check-icon hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
        </svg>
      </button>

      <button 
        type="button" 
        data-value="CONSULTATION" 
        class="reason-btn px-4 py-3 rounded-xl border-2 border-blue-600 bg-white text-blue-600 font-medium hover:bg-blue-50 transition-colors flex items-center justify-center gap-2"
      >
        <span>CONSULTATION</span>
        <svg class="check-icon hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
        </svg>
      </button>

      <button 
        type="button" 
        data-value="PRODUCT DEVELOPMENT" 
        class="reason-btn px-4 py-3 rounded-xl border-2 border-blue-600 bg-white text-blue-600 font-medium hover:bg-blue-50 transition-colors flex items-center justify-center gap-2"
      >
        <span>PRODUCT DEVELOPMENT</span>
        <svg class="check-icon hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
        </svg>
      </button>

      <button 
        type="button" 
        data-value="WEB DEVELOPMENT" 
        class="reason-btn px-4 py-3 rounded-xl border-2 border-blue-600 bg-white text-blue-600 font-medium hover:bg-blue-50 transition-colors flex items-center justify-center gap-2"
      >
        <span>WEB DEVELOPMENT</span>
        <svg class="check-icon hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
        </svg>
      </button>

      <button 
        type="button" 
        data-value="GRAPHIC DESIGN" 
        class="reason-btn px-4 py-3 rounded-xl border-2 border-blue-600 bg-white text-blue-600 font-medium hover:bg-blue-50 transition-colors flex items-center justify-center gap-2"
      >
        <span>GRAPHIC DESIGN</span>
        <svg class="check-icon hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
        </svg>
      </button>

      <button 
        type="button" 
        data-value="CAD DESIGN" 
        class="reason-btn px-4 py-3 rounded-xl border-2 border-blue-600 bg-white text-blue-600 font-medium hover:bg-blue-50 transition-colors flex items-center justify-center gap-2"
      >
        <span>CAD DESIGN</span>
        <svg class="check-icon hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
        </svg>
      </button>

      <button 
        type="button" 
        data-value="3D PRINTING" 
        class="reason-btn px-4 py-3 rounded-xl border-2 border-blue-600 bg-white text-blue-600 font-medium hover:bg-blue-50 transition-colors flex items-center justify-center gap-2"
      >
        <span>3D PRINTING</span>
        <svg class="check-icon hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
        </svg>
      </button>

      <button 
        type="button" 
        data-value="COLLABORATION" 
        class="reason-btn px-4 py-3 rounded-xl border-2 border-blue-600 bg-white text-blue-600 font-medium hover:bg-blue-50 transition-colors flex items-center justify-center gap-2"
      >
        <span>COLLABORATION</span>
        <svg class="check-icon hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
        </svg>
      </button>
    </div>
    <!-- Hidden input to store selected reasons (comma-separated) -->
    <input type="hidden" name="reasons" id="selected-reasons" value="" />
  </div>

  <!-- Preferred Date & Meeting Type -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div>
      <label class="block text-sm md:text-base font-bold text-gray-900 mb-2">
        PREFERRED DATE
      </label>
      <input
        type="date"
        name="date"
        class="
          w-full px-5 py-4 rounded-xl border-2 border-gray-300
          focus:border-pink-600 focus:ring-2 focus:ring-pink-200
          bg-white text-gray-900
          transition-all duration-300
        "
      />
    </div>

    <div>
      <label class="block text-sm md:text-base font-bold text-gray-900 mb-2">
        MEETING TYPE
      </label>
      <select 
        name="meetingType"
        class="
          w-full px-5 py-4 rounded-xl border-2 border-gray-300
          focus:border-pink-600 focus:ring-2 focus:ring-pink-200
          bg-white text-gray-900
          transition-all duration-300
        "
      >
        <option value="ONLINE MEETING">ONLINE MEETING</option>
        <option value="IN-PERSON MEETING">IN-PERSON MEETING</option>
      </select>
    </div>
  </div>

  <!-- Message -->
  <div>
    <label class="block text-sm md:text-base font-bold text-gray-900 mb-2">
      MESSAGE
    </label>
    <textarea
      name="message"
      rows="5"
      placeholder="WRITE YOUR MESSAGE..."
      required
      class="
        w-full px-5 py-4 rounded-xl border-2 border-gray-300
        focus:border-pink-600 focus:ring-2 focus:ring-pink-200
        bg-white text-gray-900 placeholder-gray-400
        transition-all duration-300 resize-none
      "
    ></textarea>
  </div>

  <!-- Cloudflare Turnstile CAPTCHA -->
  <div class="cf-turnstile mt-6" data-sitekey="YOUR_TURNSTILE_SITE_KEY_HERE"></div>

  <!-- Nuclear redirect lockdown field – tells Basin to skip its own redirect -->
  <input type="hidden" name="_redirect" value="" />

  <!-- Send Button -->
  <button 
    type="submit" 
    class="
      w-full bg-pink-600 hover:bg-pink-700
      text-white font-bold py-5 px-8
      rounded-xl text-lg md:text-xl
      shadow-lg hover:shadow-xl transition-all duration-300
      disabled:opacity-50 disabled:cursor-not-allowed
    "
    id="submit-btn"
    disabled
  >
    SEND REQUEST
  </button>

  <!-- Success message (shown via JS after Basin submission) -->
  <div id="success-message" class="hidden mt-8 p-8 bg-emerald-50 border border-emerald-200 rounded-2xl text-center">
    <div class="flex flex-col items-center">
      <div class="w-16 h-16 bg-emerald-100 text-emerald-600 rounded-2xl flex items-center justify-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7" />
        </svg>
      </div>
      <h3 class="text-2xl font-bold text-emerald-800 mb-1">Message sent successfully!</h3>
      <p class="text-emerald-700">Thank you. We'll get back to you as soon as possible.</p>
    </div>
  </div>
</form>
        
      </div>

      <!-- Right: Contact Information & Map -->
      <div class="space-y-8 md:space-y-10 lg:space-y-12">
        <div class="
          border-4 border-pink-600 rounded-none
          bg-white shadow-2xl p-6 md:p-8 lg:p-10
        ">
          <h2 class="
            text-3xl md:text-4xl lg:text-5xl
            font-black text-gray-900 mb-8 md:mb-10
          ">
            CONTACT<br />
            INFORMATION
          </h2>

          <div class="space-y-6 md:space-y-8">
            <div>
              <p class="text-lg md:text-xl font-bold text-gray-900 mb-2">
                PHONE:
              </p>
              <p class="text-base md:text-lg text-gray-700">
                +27 76 818 3494
              </p>
            </div>

            <div>
              <p class="text-lg md:text-xl font-bold text-gray-900 mb-2">
                EMAIL:
              </p>
              <p class="text-base md:text-lg text-gray-700">
                info@reserveddesigns.co.za
              </p>
            </div>

            <div>
              <p class="text-lg md:text-xl font-bold text-gray-900 mb-2">
                LOCATION:
              </p>
              <p class="text-base md:text-lg text-gray-700">
                8th floor, Nedbank Building, 85 Main Street,<br />
                Johannesburg, RSA
              </p>
            </div>
          </div>
        </div>

        <!-- Google Maps Iframe -->
        <div class="rounded-none overflow-hidden shadow-2xl border-4 border-pink-600 h-[400px] md:h-[500px] lg:h-[600px]">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3579.69051663644!2d28.037884175530657!3d-26.206743977075018!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x1e950ea242cbb1e3%3A0x477d9be1beb15f4f!2s85%20Main%20St%2C%20Marshalltown%2C%20Johannesburg%2C%202107!5e0!3m2!1sen!2sza!4v1770376909222!5m2!1sen!2sza"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Cloudflare Turnstile Script (global) -->
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

 <script>
document.addEventListener("DOMContentLoaded", function () {

  const buttons = document.querySelectorAll(".reason-btn");
  const hiddenInput = document.getElementById("selected-reasons");
  const submitBtn = document.getElementById("submit-btn");
  const form = document.getElementById("contact-form");
  const successMessage = document.getElementById("success-message");

  function updateSelection() {
    const selectedValues = [];

    buttons.forEach(button => {
      if (button.classList.contains("active")) {
        selectedValues.push(button.dataset.value);
      }
    });

    hiddenInput.value = selectedValues.join(", ");
    submitBtn.disabled = selectedValues.length === 0;
  }

  buttons.forEach(button => {
    button.addEventListener("click", function () {

      // Toggle active class
      button.classList.toggle("active");

      // Toggle visual styles (Tailwind classes example)
      button.classList.toggle("bg-blue-600");
      button.classList.toggle("text-white");
      button.classList.toggle("border-blue-800");

      button.classList.toggle("bg-white");
      button.classList.toggle("text-blue-600");
      button.classList.toggle("border-blue-600");

      updateSelection();
    });
  });

  // Basin submission with nuclear redirect lockdown + multipart/form-data
  form.addEventListener("submit", async function (e) {
    e.preventDefault();

    const originalBtnHTML = submitBtn.innerHTML;
    submitBtn.disabled = true;
    submitBtn.innerHTML = "SENDING...";

    const formData = new FormData(form);

    try {
      const response = await fetch("https://usebasin.com/f/d1012b1e0982", {
        method: "POST",
        body: formData,
        redirect: "manual"   // prevents browser from following any 3xx
      });

      if (response.ok) {
        // Reset form
        form.reset();

        // Reset reason buttons
        buttons.forEach(button => {
          button.classList.remove("active", "bg-blue-600", "text-white", "border-blue-800");
          button.classList.add("bg-white", "text-blue-600", "border-blue-600");
        });
        hiddenInput.value = "";
        updateSelection();

        // Show success message
        successMessage.classList.remove("hidden");

        // Auto-hide success after 8 seconds so user can submit again if needed
        setTimeout(() => {
          successMessage.classList.add("hidden");
        }, 8000);
      } else {
        alert("Submission failed. Please try again.");
      }
    } catch (err) {
      console.error(err);
      alert("Network error – please check your connection and try again.");
    } finally {
      submitBtn.innerHTML = originalBtnHTML;
      // disabled state is already handled by updateSelection() after reset
    }
  });

});
</script>

<!-- Add hidden input for Turnstile token if needed -->
<input type="hidden" name="cf-turnstile-response" id="cf-turnstile-response" />

</MainLayout>