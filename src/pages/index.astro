<!-- ═══════════════════════════════════════════════════════════
     PAGE SCRIPTS — scroll animations & word highlights
     ═══════════════════════════════════════════════════════════ -->
<script>
(function () {

  // ── Helper: observe once at 70% threshold ─────────────────
  function observeAt70(selector: string, onVisible: (el: Element, i: number) => void) {
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          onVisible(entry.target, 0);
          obs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.7 });

    document.querySelectorAll(selector).forEach(el => obs.observe(el));
  }

  // ── Helper: observe once at 20% threshold (earlier, for groups) ──
  function observeSection(id: string, onVisible: (section: Element) => void) {
    const section = document.getElementById(id);
    if (!section) return;
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          onVisible(section);
          obs.unobserve(section);
        }
      });
    }, { threshold: 0.2 });
    obs.observe(section);
  }

  // ══════════════════════════════════════════════════════════
  // 1. PAIN SECTION — staggered card entry
  // ══════════════════════════════════════════════════════════
  observeSection('pain-section', () => {
    document.querySelectorAll('#pain-section .section-card').forEach((card, i) => {
      const delay = parseInt((card as HTMLElement).style.transitionDelay) || i * 120;
      setTimeout(() => {
        (card as HTMLElement).style.transition = 'opacity 0.6s ease-out, transform 0.6s ease-out';
        card.classList.remove('opacity-0', 'translate-y-8');
      }, delay);
    });
  });

  // 2. PAIN SECTION — highlight "execution." at 70% in view
  observeAt70('#pain-section .highlight-word', (el) => {
    const line = el.querySelector('.highlight-underline') as HTMLElement;
    if (line) {
      setTimeout(() => { line.style.width = '100%'; }, 200);
    }
    (el as HTMLElement).style.color = '#E91E8C';
    (el as HTMLElement).style.transition = 'color 0.5s ease-out';
  });

  // ══════════════════════════════════════════════════════════
  // 3. INTRO SECTION — slide in left/right
  // ══════════════════════════════════════════════════════════
  observeSection('intro-section', () => {
    const left  = document.querySelector('#intro-section .intro-left') as HTMLElement;
    const right = document.querySelector('#intro-section .intro-right') as HTMLElement;
    if (left)  { left.classList.remove('opacity-0', '-translate-x-8');  }
    if (right) {
      setTimeout(() => { right.classList.remove('opacity-0', 'translate-x-8'); }, 150);
    }
  });

  // ══════════════════════════════════════════════════════════
  // 4. DELIVERABLES — pop in
  // ══════════════════════════════════════════════════════════
  observeSection('deliverables-section', () => {
    document.querySelectorAll('#deliverables-section .deliverable-card').forEach((card, i) => {
      const delay = i * 100;
      setTimeout(() => {
        card.classList.remove('opacity-0', 'scale-95');
      }, delay);
    });
  });

  // ══════════════════════════════════════════════════════════
  // 5. FIT SECTION — slide in from right
  // ══════════════════════════════════════════════════════════
  observeSection('fit-section', () => {
    document.querySelectorAll('#fit-section .fit-item').forEach((item, i) => {
      const delay = i * 100;
      setTimeout(() => {
        item.classList.remove('opacity-0', 'translate-x-4');
      }, delay);
    });
  });

  // 6. FIT SECTION — highlight "READY TO SHIP." at 70%
  observeAt70('#fit-section .fit-highlight-word', (el) => {
    const line = el.querySelector('.fit-highlight-line') as HTMLElement;
    if (line) {
      setTimeout(() => { line.style.width = '100%'; }, 200);
    }
    (el as HTMLElement).style.color = '#4169E1';
    (el as HTMLElement).style.transition = 'color 0.5s ease-out';
    (el as HTMLElement).style.fontWeight = '900';
  });

  // ══════════════════════════════════════════════════════════
  // 7. BUILD CTA SECTION — lines fade up sequentially
  // ══════════════════════════════════════════════════════════
  observeSection('build-cta-section', () => {
    document.querySelectorAll('#build-cta-section .build-line').forEach((line, i) => {
      const delay = i * 150;
      setTimeout(() => {
        line.classList.remove('opacity-0', 'translate-y-4');
      }, delay);
    });
  });

  // ══════════════════════════════════════════════════════════
  // 8. TESTIMONIALS — staggered slide up
  // ══════════════════════════════════════════════════════════
  observeSection('testimonials-section', () => {
    document.querySelectorAll('#testimonials-section .testimonial-card').forEach((card, i) => {
      const delay = i * 100;
      setTimeout(() => {
        card.classList.remove('opacity-0', 'translate-y-6');
      }, delay);
    });
  });

})();
</script>

