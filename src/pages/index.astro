---
import MainLayout from '../layouts/MainLayout.astro';
import PortfolioCard from '../components/PortfolioCard.astro';
import BlogCard from '../components/BlogCard.astro';
import PricingSection from '../components/PricingSection.astro';
import ValidateIdea from '../components/ValidateIdea.astro';
import InfiniteSlider from "../components/InfiniteSlider.astro";
---

<MainLayout title="Product Development Design Studio - Turn Ideas into Reality"
  description="We specialise in turning ideas into market-ready everyday products that people love, backed by top-tier expertise. Say hi, let's test your idea."
>

<!-- ═══════════════════════════════════════════════════════════
     HERO — Video Background
     ═══════════════════════════════════════════════════════════ -->
<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-[#0a0a0a]">

  <!-- Video Background -->
  <div class="absolute inset-0 w-full h-full">
    <video
      autoplay
      muted
      loop
      playsinline
      class="absolute inset-0 w-full h-full object-cover"
    >
      <source src="/videos/hero-animation.webm" type="video/webm">
      <source src="/images/reserved-designs-animated-logo.mp8 type="video/mp4">
    </video>
    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/50 to-black/70"></div>
  </div>

  <!-- Content — reduced font so video breathes -->
  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black tracking-tight text-white leading-tight mb-5">
        TURN YOUR IDEA INTO<br>
        <span class="bg-gradient-to-r from-[#00f5ff] via-[#ff00ff] to-[#ff0088] bg-clip-text text-transparent">
          A WORKING PRODUCT IN FEW DAYS
        </span>
      </h1>

      <p class="text-base sm:text-lg md:text-xl text-gray-300 mb-10 max-w-xl mx-auto leading-relaxed">
        We turn vague ideas into real, working, testable, and market-ready toys, gadgets, apps and everyday products people love and talk about.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/intake"
          class="bg-gradient-to-r from-[#00f5ff] to-[#ff0088] hover:from-[#00e6ff] hover:to-[#ff1a8c] text-white font-semibold text-base px-8 py-3.5 rounded-2xl transition-all duration-300 hover:scale-105"
        >
          Hi, Let's Start Your Project
        </a>

        <a
          href="/portfolio"
          class="border border-white/50 hover:border-white text-white font-semibold text-base px-8 py-3.5 rounded-2xl transition-all duration-300 hover:bg-white/10"
        >
          See Proof Of Transformation
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 text-white/60 animate-bounce">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════
     PAIN SECTION — "You have the idea..."
     Animation: cards fade-slide-up staggered on scroll
     Highlight: key phrase at 70% in view
     ═══════════════════════════════════════════════════════════ -->
<section class="bg-[#0a0a0a] py-28" id="pain-section">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Badge -->
    <div class="flex justify-center mb-6">
      <div class="bg-[#E91E8C] text-white text-xs font-semibold tracking-widest px-6 py-2 rounded-full">
        YOU'RE NOT ALONE
      </div>
    </div>

    <!-- Headline with highlight words -->
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tighter text-white leading-tight">
        You have the idea...<br>
        For a physical product or app/software<br>
        but not the
        <span class="highlight-word inline-block relative">
          execution.
          <span class="highlight-underline absolute left-0 bottom-0 h-[3px] w-0 bg-[#E91E8C] transition-all duration-700 ease-out rounded-full"></span>
        </span>
      </h2>
      <div class="h-px w-16 bg-[#E91E8C] mx-auto mt-8"></div>
    </div>

    <!-- Three Cards — staggered entry -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">

      <div class="section-card opacity-0 translate-y-8 bg-[#111827] rounded-3xl p-8 hover:-translate-y-2 transition-all duration-300 group" style="transition-delay: 0ms;">
        <div class="w-12 h-12 bg-[#E91E8C]/10 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
          <span class="text-3xl">🧠</span>
        </div>
        <h3 class="text-xl font-semibold text-white mb-4">The idea has lived for months (or years) in your head</h3>
        <p class="text-gray-400 leading-relaxed text-sm">
          You keep thinking about it. You sketch it on every page of your notebooks. But it never leaves your head.
        </p>
      </div>

      <div class="section-card opacity-0 translate-y-8 bg-[#111827] rounded-3xl p-8 hover:-translate-y-2 transition-all duration-300 group" style="transition-delay: 120ms;">
        <div class="w-12 h-12 bg-[#E91E8C]/10 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
          <span class="text-3xl">📐</span>
        </div>
        <h3 class="text-xl font-semibold text-white mb-4">You don't know how to design it</h3>
        <p class="text-gray-400 leading-relaxed text-sm">
          Multiple design tools feel impossible to learn. You're not an engineer. You just want the thing to exist.
        </p>
      </div>

      <div class="section-card opacity-0 translate-y-8 bg-[#111827] rounded-3xl p-8 hover:-translate-y-2 transition-all duration-300 group" style="transition-delay: 240ms;">
        <div class="w-12 h-12 bg-[#E91E8C]/10 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
          <span class="text-3xl">💰</span>
        </div>
        <h3 class="text-xl font-semibold text-white mb-4">Investors and funders ignore you</h3>
        <p class="text-gray-400 leading-relaxed text-sm">
          No proper documentation. No display or functional prototype. They don't take "idea people" seriously.
        </p>
      </div>

    </div>

    <!-- Bottom Message -->
    <div class="text-center mt-16">
      <p class="text-xl text-gray-300">So your idea stays stuck.</p>
      <p class="text-2xl font-semibold text-[#E91E8C] mt-2">We change that.</p>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════
     INTRODUCING RESERVED DESIGNS
     Animation: left text slides in, right card slides in
     ═══════════════════════════════════════════════════════════ -->
<section class="bg-white py-24" id="intro-section">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Left -->
      <div class="intro-left opacity-0 -translate-x-8 transition-all duration-700 ease-out space-y-8">
        <div>
          <span class="uppercase text-sm font-semibold tracking-widest text-[#4169E1]">INTRODUCING RESERVED DESIGNS</span>
        </div>
        <h2 class="text-4xl md:text-5xl font-black tracking-tighter text-gray-900 leading-none">
          THAT'S WHERE WE <span class="text-[#E91E8C]">COME IN</span> TO <span class="text-[#E91E8C]"> UNSTUCK</span> YOUR IDEA.
        </h2>
        <div class="space-y-5 text-lg text-gray-700 max-w-lg">
          <p>We have helped regular people, hobbysts turn vague ideas into functional prototypes. Entrepreneurs and creators to have  real, testable products to showcase to investors and sell to their audiences and designed Equipment, Jigs and Fixtures for Businesses, Workshops to have a streamlined workflow.</p>
          <p>
            Not just pretty renders.<br>
            <span class="font-semibold">Actual working prototypes</span> you can hold, test, and pitch to investors — even shelf-ready to sell.
          </p>
        </div>
        <div class="pt-6 border-t border-gray-200">
          <p class="inline-flex items-center gap-3 text-sm font-medium uppercase tracking-widest text-[#E91E8C]">
            <span class="h-px w-12 bg-[#E91E8C]"></span>
            NO TECHNICAL SKILLS REQUIRED
            <span class="h-px w-12 bg-[#E91E8C]"></span>
          </p>
        </div>
      </div>

<!-- Right Column -->
<div class="intro-right opacity-0 translate-x-8 transition-all duration-700 ease-out delay-150 bg-[#0a0a0a] rounded-3xl p-10 text-white">
  
  <div class="uppercase text-xs tracking-[2px] text-[#E91E8C] font-semibold mb-8">YOU GET</div>
  
  <div class="space-y-10">
    <div class="flex gap-6">
      <div class="text-[#E91E8C] font-bold text-3xl">01</div>
      <div><p class="text-lg leading-tight">Design & Engineering support</p></div>
    </div>
    <div class="flex gap-6">
      <div class="text-[#E91E8C] font-bold text-3xl">02</div>
      <div><p class="text-lg leading-tight">Product visualisation</p></div>
    </div>
    <div class="flex gap-6">
      <div class="text-[#E91E8C] font-bold text-3xl">03</div>
      <div><p class="text-lg leading-tight">Functional prototype</p></div>
    </div>
    <div class="flex gap-6">
      <div class="text-[#E91E8C] font-bold text-3xl">04</div>
      <div><p class="text-lg leading-tight">Manufacturing & Launch Guidance</p></div>
    </div>
  </div>

  <!-- Lightweight Automatic Image Slider -->
  <div class="mt-12">
    <div id="product-slider" class="relative w-full aspect-[4/3] rounded-2xl overflow-hidden bg-black shadow-2xl">
      
      <!-- Slides -->
      <div class="slider-container relative h-full">
        <img src="/images/sketch.jpg" 
             alt="Initial sketch of Mi-fi router phone case" 
             class="slider-image absolute inset-0 w-full h-full object-cover transition-opacity duration-700">
        
        <img src="/images/cad-model.jpg" 
             alt="CAD model of Mi-fi router phone case" 
             class="slider-image absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-700">
        
        <img src="/images/3d-printed.jpg" 
             alt="3D printed functional prototype of Mi-fi router phone case" 
             class="slider-image absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-700">
      </div>

      <!-- Optional subtle progress bar -->
      <div class="absolute bottom-0 left-0 h-0.5 bg-[#E91E8C] transition-all duration-700" id="progress-bar"></div>
    </div>
  </div>

  <!-- Testimonial -->
  <div class="mt-8 bg-[#111827] rounded-2xl p-6">
    <p class="text-base leading-relaxed italic text-gray-300">
      "I went from a sketch to holding my product in 18 days. This is the missing piece every maker needs."
    </p>
    <div class="mt-4 text-sm text-gray-400">— LinkPoD (Mi-fi router pouch X stand)</div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const images = document.querySelectorAll('.slider-image');
    let current = 0;
    const intervalTime = 2800; // 2.8 seconds per slide (feels premium but fast)

    function nextSlide() {
      images[current].classList.add('opacity-0');
      current = (current + 1) % images.length;
      images[current].classList.remove('opacity-0');
    }

    // Start automatic slider
    setInterval(nextSlide, intervalTime);

    // Optional: Progress bar animation
    const progressBar = document.getElementById('progress-bar');
    function animateProgress() {
      progressBar.style.width = '0%';
      setTimeout(() => {
        progressBar.style.transitionDuration = `${intervalTime}ms`;
        progressBar.style.width = '100%';
      }, 50);
    }

    animateProgress();
    setInterval(() => {
      animateProgress();
    }, intervalTime);
  });
</script>

    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════
     WHAT YOU'LL WALK AWAY WITH
     Animation: cards pop in on scroll
     ═══════════════════════════════════════════════════════════ -->
<section class="bg-white py-24 border-t border-gray-100" id="deliverables-section">
  <div class="max-w-6xl mx-auto px-6">

    <div class="flex items-center gap-4 mb-14">
      <div class="h-px w-8 bg-[#E91E8C]"></div>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-gray-900">
        What you'll walk away with
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">

      <div class="deliverable-card opacity-0 scale-95 transition-all duration-500 ease-out group bg-white border border-gray-100 rounded-3xl p-8 hover:shadow-xl hover:-translate-y-1" style="transition-delay:0ms;">
        <div class="h-44 flex items-center justify-center mb-6 bg-gray-50 rounded-2xl overflow-hidden">
          <img src="/images/reserved-designs-offers-professional-cad-services-&-engineering-support.avif" alt="Professional 3D CAD Design" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">Design<br>& Engineering support</h3>
        <p class="text-gray-600 leading-relaxed text-sm">
          Professional 3D CAD design for physical products and annotated code in plain English for software, app and website development.
        </p>
      </div>

      <div class="deliverable-card opacity-0 scale-95 transition-all duration-500 ease-out group bg-white border border-gray-100 rounded-3xl p-8 hover:shadow-xl hover:-translate-y-1" style="transition-delay:100ms;">
        <div class="h-44 flex items-center justify-center mb-6 bg-gray-50 rounded-2xl overflow-hidden">
          <img src="/images/reserved-designs-user-flow-ui-ux-animation.avif" alt="Product visualisation" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">Product Visualisation<br>& User Flow Animation</h3>
        <p class="text-gray-600 leading-relaxed text-sm">
          Interactive 3D visualisations and user flow animations to showcase your product's functionality and design.
        </p>
      </div>

      <div class="deliverable-card opacity-0 scale-95 transition-all duration-500 ease-out group bg-white border border-gray-100 rounded-3xl p-8 hover:shadow-xl hover:-translate-y-1" style="transition-delay:200ms;">
        <div class="h-44 flex items-center justify-center mb-6 bg-gray-50 rounded-2xl overflow-hidden">
          <img src="/images/reserved-designs-make-prototypes-for-all-your-design-needs.avif" alt="Prototype and investor pitch" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">Prototype<br>& Investor Pitch preparation</h3>
        <p class="text-gray-600 leading-relaxed text-sm">
          A functional prototype and a compelling investor pitch deck and exhibition stand to showcase your product professionally.
        </p>
      </div>

      <div class="deliverable-card opacity-0 scale-95 transition-all duration-500 ease-out group bg-white border border-gray-100 rounded-3xl p-8 hover:shadow-xl hover:-translate-y-1" style="transition-delay:300ms;">
        <div class="h-44 flex items-center justify-center mb-6 bg-gray-50 rounded-2xl overflow-hidden">
          <img src="/images/reserved-designs-guides-you-to-right-manufacturers-for-your-projects.avif" alt="Clear next steps roadmap" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">Clear next<br>steps roadmap</h3>
        <p class="text-gray-600 leading-relaxed text-sm">
          A clear, actionable plan to guide your product through post-launch, maintenance and updates — keeping it relevant for years to come.
        </p>
      </div>

    </div>

    <div class="text-center mt-14">
      <a
        href="/intake"
        class="inline-block bg-black hover:bg-gray-900 text-white font-semibold text-base px-10 py-4 rounded-2xl transition-all duration-300 hover:scale-105"
      >
        GET YOUR IDEA UNSTUCK
      </a>
    </div>

  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════
     PROOF OF TRANSFORMATION — Portfolio
     Animation: cards slide up on scroll
     ═══════════════════════════════════════════════════════════ -->
<section class="bg-[#0a0a0a] py-24 px-4 sm:px-6 lg:px-8" id="portfolio-section">
  <div class="max-w-7xl mx-auto">

    <div class="text-center mb-16 animate-on-scroll">
      <h2 class="section-title text-white">
        OUR <span class="gradient-text">PROOF OF TRANSFORMATION</span>
      </h2>
      <p class="text-xl text-gray-400 mt-4">
        Real work turning concepts into products people love and use daily.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">

      <PortfolioCard
        href="case-studies/shoprite-case-study.html"
        imageSrc="/images/reserved-designs-solutions-for-money-market-long-queue.avif"
        imageAlt="Solving long queues at Shoprite money market Kiosk"
        category="Customer Experience (UX)"
        categoryColor="blue-600"
        borderColor="blue-500/30"
        title="SHOPRITE MONEY MARKET KIOSK LONG QUEUE CASE STUDY"
        description="Shoprite Money Market kiosks are essential community infrastructure across South Africa especially for senior citizens, non-techy savvy, non-smart phone users and internet restricted individuals. But a broken queue system is quietly destroying the customer experience every single day. Customers wait up to 60 minutes in a blind queue, only to discover the specific service they need is offline when they finally reach the counter. They leave empty-handed and must return another day."
        partnerLabel="Eco-Lounge Sofa, Service Availability Display Monitor, Queue-Ticket System, Friendly Buddy with tablet/Ipad"
        partnerName="Shoprite Money Market Kiosk"
        data-tags="customer experience, retail, design for community, design-thinker, design development, systems designs, efficiency"
      />

      <PortfolioCard
        href="case-studies/diketo-case-study.html"
        imageSrc="/images/ls-bakery-logo-designed-by-reserved-designs.svg"
        imageAlt="Diketo game reimagined & preserved for future generations"
        category="indigenous Game Mordenization"
        categoryColor="pink-600"
        borderColor="pink-500/30"
        title="DIKETO GAME REIMAGINED"
        description="In many South African homes today, traditional indigenous games are slowly disappearing. Children are growing up surrounded by smartphones, tablets, and global entertainment, while the rich cultural games their parents and grandparents once played are fading into memory. Ndinga reimagine DIKETO game, a classic African stone-tossing game that enhances eye-hand & catching coordination without removing its soul. He adds non-toxic Glow-in-the-dark stones. Premium feel. Pure African heritage. Designed for both relaxed family play and energetic social settings."
        partnerLabel="Modernize African game, Preserve African Heritage, Game board"
        partnerName="Ndinga Dyongo"
        data-tags="indigenous Game Mordenization, game board design, package design, modernize, redesign, reinvent"
      />

    </div>

    <div class="text-center mt-14 animate-on-scroll">
      <a
        href="/portfolio"
        class="inline-block bg-gradient-to-r from-[#00f5ff] to-[#ff0088] hover:from-[#00e6ff] hover:to-[#ff1a8c] text-white font-semibold text-base px-10 py-4 rounded-2xl transition-all duration-300 hover:scale-105"
      >
        View Full Proof Of Transformation
      </a>
    </div>

  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════
     PERFECT FOR YOU IF...
     Animation: checkmarks draw in one by one
     Highlight: "READY TO SHIP" at 70% in view
     ═══════════════════════════════════════════════════════════ -->
<section class="bg-white py-24" id="fit-section">
  <div class="max-w-5xl mx-auto px-6">

    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-black tracking-tighter text-gray-900">
        THIS IS PERFECT FOR YOU
      </h2>
      <div class="flex items-center justify-center gap-3 mt-3">
        <span class="text-4xl md:text-5xl font-black tracking-tighter text-[#4169E1]">IF...</span>
      </div>
      <div class="h-px w-12 bg-[#E91E8C] mx-auto mt-3"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-10 max-w-4xl mx-auto">

      <div class="fit-item opacity-0 translate-x-4 transition-all duration-500 ease-out flex gap-5" style="transition-delay:0ms;">
        <div class="flex-shrink-0 w-9 h-9 bg-emerald-500 rounded-lg flex items-center justify-center text-white text-xl font-bold mt-1">✓</div>
        <p class="text-lg font-semibold text-gray-900 leading-tight pt-1">
          YOU HAVE A PRODUCT IDEA<br>THAT'S BEEN LIVING IN YOUR HEAD
        </p>
      </div>

      <div class="fit-item opacity-0 translate-x-4 transition-all duration-500 ease-out flex gap-5" style="transition-delay:100ms;">
        <div class="flex-shrink-0 w-9 h-9 bg-emerald-500 rounded-lg flex items-center justify-center text-white text-xl font-bold mt-1">✓</div>
        <p class="text-lg font-semibold text-gray-900 leading-tight pt-1">
          YOU WANT TO BRING IT TO LIFE —<br><span class="font-black">FAST</span>
        </p>
      </div>

      <div class="fit-item opacity-0 translate-x-4 transition-all duration-500 ease-out flex gap-5" style="transition-delay:200ms;">
        <div class="flex-shrink-0 w-9 h-9 bg-emerald-500 rounded-lg flex items-center justify-center text-white text-xl font-bold mt-1">✓</div>
        <p class="text-lg font-semibold text-gray-900 leading-tight pt-1">
