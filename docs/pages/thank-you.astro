---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Thank You">
  <section class="py-24 px-4 text-center">
    <h1 class="text-5xl md:text-7xl font-black text-pink-600 mb-8">Thank You!</h1>
    <p class="text-2xl md:text-3xl text-gray-700 max-w-3xl mx-auto">
      Your message has been sent successfully. We'll get back to you within 24–48 hours.
    </p>
    <a href="/" class="inline-block mt-12 bg-pink-600 text-white font-bold px-10 py-5 rounded-xl text-xl hover:bg-pink-700 transition">
      Back to Home
    </a>
  </section>
</MainLayout>